# =============================================================================
# Evo AI Community — Unified Environment Configuration
# =============================================================================
# Copy this file to .env to get started:
#   cp .env.example .env
#
# The default values below are tuned for the nginx-proxy setup in docker-compose.
# Public entrypoints are api.localhost and app.localhost.
# =============================================================================

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Shared database for all services
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=evoai_dev_password
POSTGRES_DATABASE=evo_community

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://:evoai_redis_pass@redis:6379
REDIS_PASSWORD=evoai_redis_pass

# =============================================================================
# PUBLIC HOSTS
# =============================================================================
# The compose file reads these to wire nginx-proxy and to build the public URLs
# exposed by the services.
BACKEND_HOST=api.localhost
FRONTEND_HOST=app.localhost

# =============================================================================
# SHARED SECRETS
# =============================================================================
# These MUST be identical across all services that use them.
# Pre-generated for development — CHANGE in production!

# Used by: auth, crm, core-service (JWT token signing)
SECRET_KEY_BASE=a]i9F#k2$Lm7Nq0R!sT4uW6xZ8bD1eG3hJ5oP7rV9yAcE2fH4jM6pS8vX0zB3dK5nQ7tU9wY1
JWT_SECRET_KEY=a]i9F#k2$Lm7Nq0R!sT4uW6xZ8bD1eG3hJ5oP7rV9yAcE2fH4jM6pS8vX0zB3dK5nQ7tU9wY1

# Used by: core-service, processor (API key encryption)
ENCRYPTION_KEY=XoQPOBw2FrzjQS11utERG9qO2MsAnXFxlhIns_uUxRk=

# Used by: auth, crm, processor (service-to-service authentication)
EVOAI_CRM_API_TOKEN=6e10e689-58ce-4416-bf0d-f5818bf2dcf8

# =============================================================================
# AUTH SERVICE (evo-auth-service-community) — Port 3001
# =============================================================================
RAILS_ENV=development
RAILS_MAX_THREADS=5
# FRONTEND_URL - public URL of the CRM frontend. Used by the auth service for
# OAuth redirects and as a webhook fallback in some channel adapters.
FRONTEND_URL=http://app.localhost
# Public URL of the auth service accessible from the browser.
AUTH_SERVICE_URL=http://api.localhost

# Doorkeeper JWT (OAuth2 tokens)
DOORKEEPER_JWT_SECRET_KEY=a]i9F#k2$Lm7Nq0R!sT4uW6xZ8bD1eG3hJ5oP7rV9yAcE2fH4jM6pS8vX0zB3dK5nQ7tU9wY1
DOORKEEPER_JWT_ALGORITHM=hs256
DOORKEEPER_JWT_ISS=evo-auth-service
DOORKEEPER_JWT_AUD=[]

# MFA issuer name shown in authenticator apps
MFA_ISSUER=EvoAI

# Email sender
MAILER_SENDER_EMAIL=noreply@evoai-community.local

# SMTP — production example using Mailgun
SMTP_ADDRESS=smtp.mailgun.org
SMTP_PORT=465
SMTP_DOMAIN=librecode.coop
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=false
SMTP_SSL=true
SMTP_USERNAME=contato@mg.librecode.coop
SMTP_PASSWORD=

# Storage — local filesystem in development
ACTIVE_STORAGE_SERVICE=local

# Sidekiq
SIDEKIQ_CONCURRENCY=10

# =============================================================================
# CRM SERVICE (evo-ai-crm-community) — Port 3000
# =============================================================================
# BACKEND_URL - public URL the CRM uses to build webhook callbacks and other
# absolute URLs sent to external integrations. MUST be overridden in production
# with the real backend hostname (e.g. https://crm.example.com). The localhost
# default below exists for local development only - leaving it unchanged in
# production now causes the CRM to refuse to boot (config/environments/production.rb
# raises if BACKEND_URL is missing or points at localhost).
BACKEND_URL=http://api.localhost
EVO_AI_CORE_SERVICE_URL=http://evo-core:5555
EVO_AUTH_SERVICE_URL=http://evo-auth:3001

# CORS — allow frontend and API origins
CORS_ORIGINS=http://app.localhost,http://api.localhost

# Disable telemetry
DISABLE_TELEMETRY=true

# License — headless auto-activation by email
# Set this to the email used in your first manual license registration.
# The evo-auth service will silently call /v1/register/auto on startup and skip
# the setup screen. Falls back to manual setup if the email isn't registered yet.
# Leave empty (or unset) to keep the default behavior (manual setup wizard).
# EVOLUTION_OPERATOR_EMAIL=operator@example.com

# Logging
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
LOG_SIZE=500

# Sign ups
ENABLE_ACCOUNT_SIGNUP=true

# Push notifications relay
ENABLE_PUSH_RELAY_SERVER=true

# Inbox events
ENABLE_INBOX_EVENTS=true

# Facebook API version (if using Facebook channel)
FB_VERIFY_TOKEN=evolution
FACEBOOK_API_VERSION=v23.0

# =============================================================================
# CORE SERVICE (evo-ai-core-service-community) — Port 5555
# =============================================================================
# Database (uses same Postgres, references Docker hostname)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=evoai_dev_password
DB_NAME=evo_community
DB_SSLMODE=disable

# Database connection pool
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m

# JWT — must match SECRET_KEY_BASE
JWT_ALGORITHM=HS256

# Evolution integration URL (points to CRM service)
EVOLUTION_BASE_URL=http://evo-crm:3000

# EvoAuth integration
EVO_AUTH_BASE_URL=http://evo-auth:3001

# AI Processor URL
AI_PROCESSOR_URL=http://evo-processor:8000
AI_PROCESSOR_VERSION=v1

# =============================================================================
# PROCESSOR SERVICE (evo-ai-processor-community) — Port 8000
# =============================================================================
# API metadata
API_TITLE=Agent Processor Community
API_DESCRIPTION=Agent Processor Community for Evo AI
API_VERSION=1.0.0
API_URL=http://api.localhost

ORGANIZATION_NAME=Evo AI
ORGANIZATION_URL=https://evoai.evoapicloud.com

# Database (Processor uses connection string format)
POSTGRES_CONNECTION_STRING=postgresql://postgres:evoai_dev_password@postgres:5432/evo_community

# Redis (Processor uses individual vars)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_SSL=false
REDIS_KEY_PREFIX=a2a:
REDIS_TTL=3600

# Tool cache
TOOLS_CACHE_ENABLED=true
TOOLS_CACHE_TTL=3600

# CRM API URL (for CRM tools)
EVO_AI_CRM_URL=http://evo-crm:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Core microservice
CORE_SERVICE_URL=http://evo-core:5555/api/v1

# App URL (public-facing)
APP_URL=http://api.localhost

# =============================================================================
# BOT RUNTIME (evo-bot-runtime) — Port 8080
# =============================================================================
LISTEN_ADDR=0.0.0.0:8080
BOT_RUNTIME_SECRET=evo-bot-runtime-dev-secret
AI_PROCESSOR_API_KEY=evo-processor-dev-api-key
AI_CALL_TIMEOUT_SECONDS=30

# Bot Runtime integration (used by CRM service to connect to bot-runtime)
BOT_RUNTIME_URL=http://evo-bot-runtime:8080
BOT_RUNTIME_POSTBACK_BASE_URL=http://evo-crm:3000

# =============================================================================
# FRONTEND (evo-ai-frontend-community) — Port 5173
# =============================================================================
# These are BUILD-TIME variables (baked into the frontend at build)
# They point at the public API host exposed by nginx-proxy.
VITE_APP_ENV=development
VITE_API_URL=http://api.localhost
VITE_AUTH_API_URL=http://api.localhost
VITE_EVOAI_API_URL=http://api.localhost
VITE_AGENT_PROCESSOR_URL=http://api.localhost
VITE_TINYMCE_API_KEY=no-api-key

# =============================================================================
# OPTIONAL — Social Channels (uncomment and configure as needed)
# =============================================================================
# # WhatsApp Cloud API
# WP_APP_ID=
# WP_VERIFY_TOKEN=evolution
# WP_APP_SECRET=
# WP_WHATSAPP_CONFIG_ID=
# WP_API_VERSION=v23.0

# # Facebook Messenger
# FB_APP_SECRET=
# FB_APP_ID=

# # Twitter / X
# TWITTER_APP_ID=
# TWITTER_CONSUMER_KEY=
# TWITTER_CONSUMER_SECRET=
# TWITTER_ENVIRONMENT=

# # Slack
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# # Google OAuth (for Gmail integration)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_CALLBACK_URL=

# =============================================================================
# OPTIONAL — Cloud Storage (default: local filesystem)
# =============================================================================
# To use Cloudflare R2, AWS S3, MinIO or any S3-compatible service:
#   1. Set ACTIVE_STORAGE_SERVICE=s3_compatible (both auth and CRM services use this var)
#   2. Fill in the bucket credentials below
#   3. Configure your bucket's CORS policy to allow GET from your frontend domain
#      (this must be done in the storage provider's dashboard — not in this file)
#
# Example for Cloudflare R2:
#   ACTIVE_STORAGE_SERVICE=s3_compatible
#   STORAGE_BUCKET_NAME=my-bucket
#   STORAGE_ACCESS_KEY_ID=<R2 Access Key ID>
#   STORAGE_SECRET_ACCESS_KEY=<R2 Secret Access Key>
#   STORAGE_REGION=auto
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#
# STORAGE_BUCKET_NAME=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_REGION=
# STORAGE_ENDPOINT=

# =============================================================================
# OPTIONAL — APM & Monitoring
# =============================================================================
# # Sentry
# SENTRY_DSN=

# # Datadog
# DD_TRACE_AGENT_URL=

# # NewRelic
# NEW_RELIC_LICENSE_KEY=

# # OpenAI (for AI-powered features)
# OPENAI_API_KEY=
